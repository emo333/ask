#!/usr/bin/env bash
# This script is a single-file bash CLI that sends a prompt to Opencode Zen's API
# and prints the response in the terminal. It is meant to be run directly as either ./ask or,
# if you place it somewhere else like ~/.local/bin/ and that has been added to your PATH, as ask.
set -euo pipefail

# ########################################
# ########################################
# Path to the Opencode authentication file. The Zen API key lives here after
# running `opencode auth login --provider zen`. Guard it like your favorite snack.
#
# Note: You do not HAVE to install/run opencode to use ask.
#       But you do have to register an opencode.ai/zen account and get an API key.
#       Once you get your API key, create a file auth.json and put it wherever you want on your system.
#       I recommend the conventional location: ~/.local/share/opencode/auth.json
#
#       the file needs to contain the following:
#
#       {
#          "opencode": {
#           "type": "api",
#           "key": "YOUR API key GOES HERE"
#         }
#       }
#
#       If you put the file somewhere other than the conventional location,
#       then you will change the AUTH_FILE= line below to match where you put the file.
readonly AUTH_FILE="${HOME}/.local/share/opencode/auth.json"
# ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^
# ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^

# ########################################
# ########################################
# Where user defaults (model, cost threshold, pricing cache, skills) are stored.
readonly CONFIG_DIR="${HOME}/.config/ask"
readonly CONFIG_FILE="${CONFIG_DIR}/ask.conf"
readonly SKILLS_FILE="${CONFIG_DIR}/SKILLS.md"
readonly DEFAULT_MODEL="big-pickle"
readonly DEFAULT_COST_THRESHOLD="2.00"
readonly ZEN_BASE_URL="https://opencode.ai/zen"
readonly ZEN_DOCS_URL="https://opencode.ai/docs/zen/"
readonly ZEN_HOME_URL="https://opencode.ai/"

# Default system skill prepended to every prompt unless overridden by SKILLS.md.
readonly DEFAULT_SYSTEM_SKILL="You: expert in computers. All answers to be cited. Cites dated from when cite was obtained in your training data. Responses should be markdown with diagrams if helpful, unless response less than 10 lines. Answer quick, short, and to the point. Do not ask for clarifications. If you make assumptions, include those assumptions in response."

# When true, the API accepts requests without an API key for the big-pickle model.
USE_NO_AUTH=false
API_KEY=""

# Runtime state for the progress spinner.
SPINNER_PID=""
SPINNER_START=""
# ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^
# ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^

die() {
  printf '%s\n' "$*" >&2
  exit 1
}

require_cmd() {
  local cmd
  for cmd in "$@"; do
    if ! command -v "$cmd" >/dev/null 2>&1; then
      die "Error: required command not found: ${cmd}"
    fi
  done
}

# Persist current model/threshold/pricing to the config file atomically.
# Use declare -gA so sourcing the config from inside a function still updates
# the global PRICING map (plain `declare -A` would otherwise be function-local).
write_config() {
  local pricing_date="${1:-${MODEL_PRICING_DATE:-}}"
  local tmp key
  mkdir -p "$CONFIG_DIR"
  tmp="$(mktemp "${CONFIG_DIR}/.ask.conf.XXXXXX")"
  {
    printf 'MODEL=%q\n' "$MODEL"
    printf 'COST_THRESHOLD=%q\n' "$COST_THRESHOLD"
    printf 'MODEL_PRICING_DATE=%q\n' "$pricing_date"
    printf 'declare -gA PRICING=(\n'
    if ((${#PRICING[@]} > 0)); then
      for key in "${!PRICING[@]}"; do
        printf '  [%q]=%q\n' "$key" "${PRICING[$key]}"
      done
    fi
    printf ')\n'
  } >"$tmp"
  mv -f "$tmp" "$CONFIG_FILE"
}

# Print the help(usage) message to the terminal.
print_usage() {
  cat <<EOF
Usage: ask [options] [prompt]

Send a prompt to OpenCode Zen and print the response.

Options:
  -m                   List available models with pricing and select one
  -m <model>           Set model directly
  -c                   Set cost warning threshold (interactive)
  -c <amount>          Set cost warning threshold directly (e.g. 2.50)
  -s                   Edit the system skill (SKILLS.md) in \$EDITOR
  -t                   Force plain terminal output (do not use bat)
  -h, --h, --help      Show this help message

A system skill is automatically prepended to every prompt from
${SKILLS_FILE}, or from the built-in default if that file does not exist.

Without arguments, prompts interactively.
With arguments, sends them as the prompt.

Attach a file by ending the prompt with: < path/to/file
  ask summarize this file '<' /path/to/file.txt
  ask 'summarize this file < /path/to/file.txt'
  ask                             # then type: summarize this file < /path/to/file.txt
  (The '<' must be quoted/escaped on the command line because it is a redirection operator.)

Config: ~/.config/ask/ask.conf
Model defaults to: big-pickle
Cost threshold defaults to: 2.00
EOF
}

# Return the system skill to prepend to every prompt. Uses SKILLS.md when it
# exists, otherwise falls back to the built-in DEFAULT_SYSTEM_SKILL.
get_system_skill() {
  if [[ -f "$SKILLS_FILE" ]]; then
    cat "$SKILLS_FILE" 2>/dev/null || printf '%s\n' "$DEFAULT_SYSTEM_SKILL"
  else
    printf '%s\n' "$DEFAULT_SYSTEM_SKILL"
  fi
}

# Open the user's SKILLS.md in $EDITOR. Creates the file with the default
# system skill if it does not already exist.
edit_skills() {
  mkdir -p "$CONFIG_DIR"
  if [[ ! -f "$SKILLS_FILE" ]]; then
    printf '%s\n' "$DEFAULT_SYSTEM_SKILL" >"$SKILLS_FILE"
  fi
  if [[ -z "${EDITOR:-}" ]]; then
    die "Error: EDITOR environment variable is not set."
  fi
  "$EDITOR" "$SKILLS_FILE"
  exit 0
}

stop_spinner() {
  # ${1:-true} means "use the first argument, or default to true".
  local show_time="${1:-true}"
  if [[ -n "$SPINNER_PID" ]] && kill -0 "$SPINNER_PID" 2>/dev/null; then
    kill "$SPINNER_PID" 2>/dev/null || true
    # wait ensures the background process is fully gone before continuing.
    wait "$SPINNER_PID" 2>/dev/null || true
  fi
  if [[ "$show_time" == true && -n "$SPINNER_START" ]]; then
    local now elapsed mins secs
    now="$(date +%s)"
    elapsed=$((now - SPINNER_START))
    mins=$((elapsed / 60))
    secs=$((elapsed % 60))
    # Clear the spinner line, then print the final elapsed time.
    printf '\r%-80s\r' "" >&2
    printf '  completed in %02d:%02d\n' "$mins" "$secs" >&2
  else
    printf '\r%-80s\r' "" >&2
  fi
  SPINNER_PID=""
  SPINNER_START=""
  # Remove the Ctrl+C trap now that the spinner is gone.
  trap - INT
}

start_spinner() {
  # Use epoch seconds so the spinner subshell and parent share the same clock.
  SPINNER_START="$(date +%s)"
  (
    local i=0
    local spin_chars='|/-' # fourth frame is a backslash, appended below
    spin_chars+=$'\\'
    local elapsed mins secs char now
    while true; do
      now="$(date +%s)"
      elapsed=$((now - SPINNER_START))
      mins=$((elapsed / 60))
      secs=$((elapsed % 60))
      char="${spin_chars:$((i % 4)):1}"
      # \r returns to the start of the line so each frame overwrites the last.
      # >&2 sends the output to stderr so it does not mix with piped stdout.
      printf '\r  %s %02d:%02d waiting for response...' "$char" "$mins" "$secs" >&2
      i=$((i + 1))
      sleep 0.1
    done
  ) &
  # `$!` is the process ID of the background job we just started.
  SPINNER_PID=$!
  # Set a trap: if the user presses Ctrl+C, stop the spinner and exit.
  trap 'stop_spinner false; exit 130' INT
}

cleanup() {
  stop_spinner false 2>/dev/null || true
  API_KEY=""
}
trap cleanup EXIT

# ########################################
# ########################################
# Handle help and skills editing before the authentication check. These are
# local-only operations, so they don't need to bribe the API gatekeeper.
if [[ "${1:-}" == "-h" || "${1:-}" == "--h" || "${1:-}" == "--help" ]]; then
  print_usage
  exit 0
fi

if [[ "${1:-}" == "-s" ]]; then
  edit_skills
fi

require_cmd jq curl

# If the user wants to change models but has no auth file, there is no point in
# probing the API. Only the free big-pickle model is available without a key.
if [[ ! -f "$AUTH_FILE" ]]; then
  local_arg=""
  for local_arg in "$@"; do
    if [[ "$local_arg" == "-m" ]]; then
      die "Since you do not have an Zen API key, you can only use the big-pickle model."
    fi
  done
fi
# ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^
# ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^

# ########################################
# ########################################
# Extract and validate the Zen API key before any network operation. No key, no query.
# This is just the file with path, not the actual file content or the actual key, so no need to protect it.
if [[ ! -f "$AUTH_FILE" ]]; then
  # Some Zen endpoints accept requests without an API key for the free big-pickle
  # model. Probe the API with a tiny payload before giving up.
  if command -v tput >/dev/null 2>&1; then
    tput setaf 6
  fi
  printf '%s\n' "Checking availability of free big-pickle api..."
  if command -v tput >/dev/null 2>&1; then
    tput sgr0
  fi
  start_spinner
  NO_AUTH_STATUS="$(
    curl -sS -o /dev/null -w '%{http_code}' \
      --max-time 30 \
      "${ZEN_BASE_URL}/v1/chat/completions" \
      -H "Content-Type: application/json" \
      -d '{"model": "big-pickle", "messages": [{"role": "user", "content": "hello"}]}' 2>/dev/null || printf '000'
  )"
  stop_spinner
  if [[ "$NO_AUTH_STATUS" == "200" ]]; then
    USE_NO_AUTH=true
  else
    printf '%s\n' "Error: OpenCode authentication file not found at ${AUTH_FILE}"
    printf '%s\n' "Please run 'opencode auth login --provider zen' first. Or follow instructions in ask for use without opencode installed."
    exit 1
  fi
else
  # Try several common JSON paths for the Zen API key. The `//` operator in jq
  # means "use the first one that is not null or empty". `.zen // empty` at the end
  # catches the case where the key is stored as a plain string.
  #
  # if we successfully get the key, we will protect it by clearing it from memory
  # as soon as we are done with it throughout the script.
  #
  API_KEY="$(jq -r '.opencode.key // .providers.zen.apiKey // .zen.apiKey // .zen // empty' "$AUTH_FILE")"

  # First fallback: some older auth files store the key directly under `.zen`.
  # If the first extraction failed, try that specific field.
  if [[ -z "$API_KEY" || "$API_KEY" == "null" ]]; then
    API_KEY="$(jq -r '.zen // empty' "$AUTH_FILE")"
  fi

  if [[ -z "$API_KEY" || "$API_KEY" == "null" ]]; then
    printf '%s\n' "Error: Could not find an active Zen API key inside ${AUTH_FILE}"
    printf '%s\n' "Please ensure you have authenticated your local instance with opencode. Or follow instructions in ask for use without opencode installed."
    exit 1
  fi
fi
# ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^
# ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^

# Source config at top level for defaults.
# Initialize variables first so the sourced file can overwrite them.
MODEL=""
MODEL_PRICING_DATE=""
COST_THRESHOLD="$DEFAULT_COST_THRESHOLD"
# `declare -A` creates an associative array (a hash map). PRICING maps model ID
# to a "input_cost output_cost" string.
declare -A PRICING=()
if [[ -f "$CONFIG_FILE" ]]; then
  # shellcheck source=/dev/null
  source "$CONFIG_FILE"
fi
# Use the default model if the config did not set one.
if [[ -z "$MODEL" ]]; then
  MODEL="$DEFAULT_MODEL"
fi
# Use the default threshold if the config did not set one.
if [[ -z "$COST_THRESHOLD" ]]; then
  COST_THRESHOLD="$DEFAULT_COST_THRESHOLD"
fi

# Make sure the machine is actually online before bothering the API. If not,
# we bail with a friendly "No internet connection available." message.
require_internet() {
  if ! curl -sS --max-time 5 -o /dev/null "$ZEN_HOME_URL" 2>/dev/null; then
    die "No internet connection available."
  fi
}

# ########################################
# ########################################
# --- Interactive model selection ---

# Lists available Zen models with pricing, lets the user pick one, and writes
# the choice back to the config file. Also refreshes pricing once per day.
select_model_interactive() {
  if [[ "$USE_NO_AUTH" == true ]]; then
    printf '%s\n' "Since you do not have an Zen API key, you can only use the big-pickle model." >&2
    return 1
  fi
  require_internet

  if [[ ! -f "$CONFIG_FILE" ]]; then
    printf '%s\n' "No config file found at ${CONFIG_FILE}"
    printf '\n'
    printf '%s\n' "To change models, first create the config directory and file:"
    printf '\n'
    printf '  mkdir -p %s\n' "$CONFIG_DIR"
    printf "  echo 'MODEL=model-name' > %s\n" "$CONFIG_FILE"
    printf '\n'
    printf '%s\n' "Or set a model directly with:"
    printf '  ask -m <model-name>\n'
    return 1
  fi

  local TODAY
  # date +%Y-%m-%d produces today's date as a string like "2026-07-01".
  TODAY="$(date +%Y-%m-%d)"

  # Only fetch pricing once per day. MODEL_PRICING_DATE is stored in the config.
  if [[ "$MODEL_PRICING_DATE" != "$TODAY" ]]; then
    printf '%s\n' "Fetching latest pricing from opencode.ai/docs/zen..."
    # curl -s runs silently (no progress bar). The `|| HTML=""` part ensures the
    # script continues even if the network request fails.
    local HTML=""
    HTML="$(curl -sS --max-time 30 "$ZEN_DOCS_URL" 2>/dev/null)" || HTML=""
    if [[ -n "$HTML" ]]; then
      # The pricing page contains two HTML tables. The first maps display names
      # to API model IDs. The second maps display names to input/output prices.
      # This awk script parses both tables and merges them by display name.
      local PRICING_ENTRIES=""
      PRICING_ENTRIES="$(printf '%s' "$HTML" | grep -o 'table>.*' | awk '
BEGIN { t=0 }
{ t++; if (t>2) exit; gsub(/.*<tbody>/,""); gsub(/<\/tbody>.*/,""); body=$0 }
t==1 {
  n=split(body, rows, /<\/tr>[ \t]*<tr>/)
  for (i=1; i<=n; i++) {
    row=rows[i]; gsub(/<tr>[ \t]*|[ \t]*<\/tr>/,"",row)
    if (row=="" || row==" ") continue
    split(row, cols, /<\/td>[ \t]*<td>/)
    gsub(/<td>[ \t]*|[ \t]*<\/td>/,"",cols[1])
    gsub(/<td>[ \t]*|[ \t]*<\/td>/,"",cols[2])
    gsub(/<\/?code[^>]*>/,"",cols[1])
    gsub(/<\/?code[^>]*>/,"",cols[2])
    gsub(/^[ \t]+|[ \t]+$/,"",cols[1])
    gsub(/^[ \t]+|[ \t]+$/,"",cols[2])
    if (cols[1]!="" && cols[1]!="Model") ids[cols[1]]=cols[2]
  }
}
t==2 {
  n=split(body, rows, /<\/tr>[ \t]*<tr>/)
  for (i=1; i<=n; i++) {
    row=rows[i]; gsub(/<tr>[ \t]*|[ \t]*<\/tr>/,"",row)
    if (row=="" || row==" ") continue
    split(row, cols, /<\/td>[ \t]*<td>/)
    gsub(/<td>[ \t]*|[ \t]*<\/td>/,"",cols[1])
    gsub(/<td>[ \t]*|[ \t]*<\/td>/,"",cols[2])
    gsub(/<td>[ \t]*|[ \t]*<\/td>/,"",cols[3])
    gsub(/^[ \t]+|[ \t]+$/,"",cols[1])
    gsub(/^[ \t]+|[ \t]+$/,"",cols[2])
    gsub(/^[ \t]+|[ \t]+$/,"",cols[3])
    gsub(/\$/,"",cols[2]); gsub(/\$/,"",cols[3])
    if (cols[1]!="" && cols[1]!="Model") {
      nm=cols[1]; gsub(/ *\([^)]*\) */,"",nm); gsub(/^[ \t]+|[ \t]+$/,"",nm)
      if (!(nm in prices)) prices[nm]=cols[2]" "cols[3]
    }
  }
}
END { for (n in ids) printf "  [%s]=\"%s\"\n", ids[n], (n in prices)?prices[n]:"-- --" }
' 2>/dev/null | sort)" || PRICING_ENTRIES=""

      if [[ -n "$PRICING_ENTRIES" ]]; then
        MODEL_PRICING_DATE="$TODAY"
        {
          printf 'MODEL=%q\n' "$MODEL"
          printf 'COST_THRESHOLD=%q\n' "$COST_THRESHOLD"
          printf 'MODEL_PRICING_DATE=%q\n' "$TODAY"
          # -gA: keep PRICING global even when this file is sourced from a function.
          printf 'declare -gA PRICING=(\n'
          # Rewrite awk rows ([id]="price") into safely quoted declare -gA entries.
          while IFS= read -r pricing_line || [[ -n "$pricing_line" ]]; do
            [[ -z "$pricing_line" ]] && continue
            if [[ "$pricing_line" =~ ^[[:space:]]*\[([^\]]+)\]=\"(.*)\"[[:space:]]*$ ]]; then
              printf '  [%q]=%q\n' "${BASH_REMATCH[1]}" "${BASH_REMATCH[2]}"
            fi
          done <<<"$PRICING_ENTRIES"
          printf ')\n'
        } >"$CONFIG_FILE"
        # shellcheck source=/dev/null
        source "$CONFIG_FILE"
      else
        printf '%s\n' "Warning: Could not parse pricing data. Using cached values."
      fi
    else
      printf '%s\n' "Warning: Could not fetch pricing page. Using cached values."
    fi
  fi

  printf '%s\n' "Fetching available models..."
  local MODELS_JSON=""
  if ! MODELS_JSON="$(curl -sS --max-time 30 "${ZEN_BASE_URL}/v1/models" \
    -H "Authorization: Bearer ${API_KEY}")"; then
    printf '%s\n' "Error: Could not fetch model list (network error)."
    return 1
  fi

  # jq -r '.data[] | .id' extracts the model ID from each item in the data array.
  local MODELS=""
  MODELS="$(printf '%s' "$MODELS_JSON" | jq -r '.data[]? | .id' 2>/dev/null | sort)" || MODELS=""

  if [[ -z "$MODELS" ]]; then
    printf '%s\n' "Error: Could not fetch model list."
    return 1
  fi

  printf '\n'
  # mapfile reads lines into an array without word-splitting pitfalls.
  local -a MODEL_ARRAY=()
  mapfile -t MODEL_ARRAY <<<"$MODELS"

  # Drop a possible trailing empty element from the here-string.
  if [[ ${#MODEL_ARRAY[@]} -gt 0 && -z "${MODEL_ARRAY[-1]}" ]]; then
    unset 'MODEL_ARRAY[-1]'
  fi

  if [[ ${#MODEL_ARRAY[@]} -eq 0 ]]; then
    printf '%s\n' "Error: Could not fetch model list."
    return 1
  fi

  local i mid raw inp outp disp
  printf '  %-3s %-35s %s\n' "#" "Model" "Cost(Input/Output per 1M)"
  printf '  %-3s %-35s %s\n' "---" "-----------------------------------" "---------------------------"
  for i in "${!MODEL_ARRAY[@]}"; do
    mid="${MODEL_ARRAY[$i]}"
    raw="${PRICING[$mid]:-}"
    if [[ -z "$raw" ]]; then
      disp="--/--"
    else
      # Parameter expansion: everything before the first space is input cost.
      inp="${raw%% *}"
      # Everything after the first space is output cost.
      outp="${raw#* }"
      # Add dollar signs unless the price is "Free".
      # Use if/else — bare `[[ ]] &&` under set -e is a common silent-exit footgun.
      if [[ "$inp" != "Free" ]]; then
        inp="\$${inp}"
      fi
      if [[ "$outp" != "Free" ]]; then
        outp="\$${outp}"
      fi
      disp="${inp}/${outp}"
    fi
    printf '  %-3d %-35s %s\n' "$((i + 1))" "$mid" "$disp"
  done
  printf '\n'
  printf 'Select a model (1-%d): ' "${#MODEL_ARRAY[@]}"
  local SELECTION=""
  if ! read -r SELECTION; then
    printf '\n%s\n' "No selection made."
    return 1
  fi

  # =~ is a bash regex match. ^[0-9]+$ means "only digits".
  if [[ ! "$SELECTION" =~ ^[0-9]+$ ]] ||
    ((SELECTION < 1 || SELECTION > ${#MODEL_ARRAY[@]})); then
    printf '%s\n' "Invalid selection."
    return 1
  fi

  MODEL="${MODEL_ARRAY[$((SELECTION - 1))]}"
  write_config "$TODAY"
  printf '%s\n' "Model set to: ${MODEL}"
  return 0
}

# If the prompt ends with "< path/to/file", snag that file and append its
# contents to the prompt. We only attach real files, so math questions like
# "is 5 < 10" stay safely unchanged when no matching file lurks nearby.
attach_file_to_prompt() {
  local raw="$1"
  local path=""

  # Match a trailing " < path" where path is the final non-whitespace token.
  if [[ "$raw" =~ \<[[:space:]]+([^[:space:]]+)[[:space:]]*$ ]]; then
    path="${BASH_REMATCH[1]}"

    if [[ -f "$path" && -r "$path" ]]; then
      local prefix="${raw%< *}"
      # Strip trailing whitespace from the prefix.
      prefix="${prefix%"${prefix##*[![:space:]]}"}"
      local content=""
      if ! content="$(cat -- "$path" 2>/dev/null)"; then
        printf 'Warning: could not read file: %s\n' "$path" >&2
        printf '%s' "$raw"
        return 0
      fi

      if [[ -n "$prefix" ]]; then
        printf -- '%s\n\n--- File: %s ---\n\n%s' "$prefix" "$path" "$content"
      else
        printf -- '--- File: %s ---\n\n%s' "$path" "$content"
      fi
      return 0
    fi
  fi

  printf '%s' "$raw"
}

main() {
  # API_KEY arrives as the first positional argument. We declare it local so it
  # doesn't escape into the wild when the script is sourced.
  local API_KEY="${1:-}"
  shift || true

  # --- Global option: -t (plain terminal output) ---

  # Default to using `bat` if available. The -t flag disables this.
  local USE_BAT=true
  local -a CLEAN_ARGS=()
  local arg
  # Build a new argument list with -t removed so it does not get mistaken for
  # the prompt text or another flag.
  for arg in "$@"; do
    if [[ "$arg" == "-t" || "$arg" == "--t" ]]; then
      USE_BAT=false
    else
      CLEAN_ARGS+=("$arg")
    fi
  done
  # set -- replaces the current positional parameters with the cleaned list.
  if ((${#CLEAN_ARGS[@]} > 0)); then
    set -- "${CLEAN_ARGS[@]}"
  else
    set --
  fi

  # --- Help flag ---

  if [[ "${1:-}" == "-h" || "${1:-}" == "--h" || "${1:-}" == "--help" ]]; then
    print_usage
    API_KEY=""
    exit 0
  fi

  # --- Skills editor flag ---

  if [[ "${1:-}" == "-s" ]]; then
    edit_skills
  fi

  # --- Cost threshold flag ---

  if [[ "${1:-}" == "-c" ]]; then
    if [[ -n "${2:-}" && "${2:0:1}" != "-" ]]; then
      COST_THRESHOLD="$2"
    else
      printf 'Enter dollar cost threshold for warnings (format: 0.00): '
      read -r COST_THRESHOLD
    fi
    # Validate that the threshold is a number (e.g. 2, 2.50).
    if [[ ! "$COST_THRESHOLD" =~ ^[0-9]+(\.[0-9]+)?$ ]]; then
      die "Invalid threshold. Use a number like 2.00."
    fi
    write_config "${MODEL_PRICING_DATE:-}"
    printf 'Cost threshold set to $%s per 1M input tokens.\n' "$COST_THRESHOLD"
    exit 0
  fi

  # --- Model selection / configuration ---

  if [[ "${1:-}" == "-m" ]]; then
    if [[ "$USE_NO_AUTH" == true ]]; then
      die "Since you do not have an Zen API key, you can only use the big-pickle model."
    fi
    if [[ -n "${2:-}" && "${2:0:1}" != "-" ]]; then
      MODEL="$2"
      # Reset the pricing date so the next -m run refreshes pricing.
      write_config ""
      printf '%s\n' "Model set to: ${MODEL}"
      # Remove the -m and model-name arguments so we can check for a prompt.
      shift 2
      if [[ -z "$*" ]]; then
        exit 0
      fi
    else
      # Keep set -e from aborting before we can report a clean status.
      if select_model_interactive; then
        exit 0
      fi
      exit 1
    fi
  fi

  # When running without an API key, the only model available is big-pickle.
  # Make sure the user sees the correct model name in the prompt and messages.
  if [[ "$USE_NO_AUTH" == true ]]; then
    MODEL="big-pickle"
  fi

  # --- Prompt input ---

  local USER_PROMPT=""
  if [[ -z "${1:-}" ]]; then
    # No prompt provided on the command line, so we politely ask the user.
    if command -v tput >/dev/null 2>&1; then
      tput setaf 6
    fi
    printf 'Ask OpenCode Zen(Model: %s): ' "$MODEL"
    if command -v tput >/dev/null 2>&1; then
      tput setaf 11
    fi
    read -r USER_PROMPT
    if command -v tput >/dev/null 2>&1; then
      tput sgr0
    fi
    USER_PROMPT="$(attach_file_to_prompt "$USER_PROMPT")"
    if [[ -z "$USER_PROMPT" ]]; then
      if command -v tput >/dev/null 2>&1; then
        tput setaf 1
      fi
      printf '%s\n' "Error: Prompt cannot be empty. Exiting."
      if command -v tput >/dev/null 2>&1; then
        tput sgr0
      fi
      API_KEY=""
      exit 1
    fi
  else
    # Join all remaining arguments into one prompt string.
    USER_PROMPT="$*"
    USER_PROMPT="$(attach_file_to_prompt "$USER_PROMPT")"
  fi

  # Tack the system skill onto the front of the prompt. Custom SKILLS.md wins
  # over the built-in default — everyone can customize how they want all their prompts handled by chosen LLM.
  local SYSTEM_SKILL=""
  SYSTEM_SKILL="$(get_system_skill)"
  if [[ -n "$SYSTEM_SKILL" ]]; then
    USER_PROMPT="${SYSTEM_SKILL}

---

${USER_PROMPT}"
  fi

  # --- Cost warning ---
  #
  # This is here in case you chnaged your model to a really expensive one maybe because you wanted super accurate info or code or whatever.
  # But you forgot to change it back to a cheapo model.
  # You don't want to spend a shit ton of $ on asking a simple question to an expensive model.
  # So, this warns you.
  #
  local raw_price="${PRICING[$MODEL]:-}"
  if [[ -n "$raw_price" ]]; then
    # Extract the input cost (first word) from the "input output" string.
    local inp_cost="${raw_price%% *}"
    if [[ "$inp_cost" != "Free" && "$inp_cost" != "--" && -n "$inp_cost" ]]; then
      # awk is used here instead of bc because bc is not always installed.
      # The awk program exits with status 1 if the cost is NOT >= threshold.
      # The `!` inverts the result so the overall command succeeds when the
      # cost meets or exceeds the threshold.
      if awk "BEGIN{exit !($inp_cost >= $COST_THRESHOLD)}" 2>/dev/null; then
        local outp_cost="${raw_price#* }"
        if command -v tput >/dev/null 2>&1; then
          tput setaf 11
        fi
        printf '\n'
        printf '%s\n' "--- Cost Warning ---"
        printf 'Model: %s\n' "$MODEL"
        printf 'Cost : $%s input / $%s output per 1M tokens\n' "$inp_cost" "$outp_cost"
        printf 'Threshold: $%s per 1M input tokens\n' "$COST_THRESHOLD"
        printf 'Press Enter to continue, m to select a different model, or anything else to exit: '
        if command -v tput >/dev/null 2>&1; then
          tput sgr0
        fi
        local SWITCH_MODEL=""
        read -r SWITCH_MODEL
        if [[ "$SWITCH_MODEL" == "m" ]]; then
          printf '\n'
          select_model_interactive || exit 1
        elif [[ -n "$SWITCH_MODEL" ]]; then
          printf '%s\n' "Exiting."
          exit 0
        fi
      fi
    fi
  fi

  # One last connectivity sanity check before we fire the prompt into the cloud.
  require_internet

  # Determine which API family this model belongs to.
  # Different model families require different endpoints and request formats.
  local API_FAMILY="openai-compatible"
  case "$MODEL" in
  gemini-*) API_FAMILY="gemini" ;;
  esac

  local REQUEST_BODY=""
  local RESPONSE=""
  local PARSED_TEXT=""

  if [[ "$USE_NO_AUTH" == true ]]; then
    # No API key available, so we pin the model to the free big-pickle endpoint.
    MODEL="big-pickle"
    if command -v tput >/dev/null 2>&1; then
      tput setaf 6
    fi
    printf '%s\n' "Sending query to OpenCode Zen using model: big-pickle (no authentication)..."
    if command -v tput >/dev/null 2>&1; then
      tput sgr0
    fi

    REQUEST_BODY="$(jq -n --arg prompt "$USER_PROMPT" '{
      model: "big-pickle",
      messages: [{role: "user", content: $prompt}],
      stream: false
    }')"

    start_spinner
    RESPONSE="$(curl -sS --max-time 300 "${ZEN_BASE_URL}/v1/chat/completions" \
      -H "Content-Type: application/json" \
      -d "$REQUEST_BODY")" || true
    stop_spinner
    API_KEY=""

    PARSED_TEXT="$(printf '%s' "$RESPONSE" | jq -r '.choices[0].message.content // empty')" || PARSED_TEXT=""
  elif [[ "$API_FAMILY" == "gemini" ]]; then
    # Gemini models require a differnt request body format and response format.
    if command -v tput >/dev/null 2>&1; then
      tput setaf 6
    fi
    printf '%s\n' "Sending query to OpenCode Zen using model: ${MODEL} (Gemini native)..."
    if command -v tput >/dev/null 2>&1; then
      tput sgr0
    fi

    # Build the JSON request body with jq. Using jq avoids quoting problems
    # when the prompt contains special characters.
    REQUEST_BODY="$(jq -n --arg prompt "$USER_PROMPT" '{
      contents: [{role: "user", parts: [{text: $prompt}]}]
    }')"

    # Show the spinner while curl is waiting for a response.
    start_spinner
    RESPONSE="$(curl -sS --max-time 300 "${ZEN_BASE_URL}/v1/models/${MODEL}:generateContent" \
      -H "Content-Type: application/json" \
      -H "x-goog-api-key: ${API_KEY}" \
      -d "$REQUEST_BODY")" || true
    stop_spinner
    API_KEY=""

    # Parse the Gemini-native response format.
    PARSED_TEXT="$(printf '%s' "$RESPONSE" | jq -r '.candidates[0].content.parts[0].text // empty')" || PARSED_TEXT=""
  else
    # All of the other models require this request body format and response format.
    if command -v tput >/dev/null 2>&1; then
      tput setaf 6
    fi
    printf '%s\n' "Sending query to OpenCode Zen using model: ${MODEL}..."
    if command -v tput >/dev/null 2>&1; then
      tput sgr0
    fi

    # Build the standard OpenAI-compatible chat request body.
    REQUEST_BODY="$(jq -n --arg model "$MODEL" --arg prompt "$USER_PROMPT" '{
      model: $model,
      messages: [{role: "user", content: $prompt}],
      stream: false
    }')"

    start_spinner
    RESPONSE="$(curl -sS --max-time 300 "${ZEN_BASE_URL}/v1/chat/completions" \
      -H "Content-Type: application/json" \
      -H "Authorization: Bearer ${API_KEY}" \
      -d "$REQUEST_BODY")" || true
    stop_spinner
    API_KEY=""

    # Parse the OpenAI-compatible response format.
    PARSED_TEXT="$(printf '%s' "$RESPONSE" | jq -r '.choices[0].message.content // empty')" || PARSED_TEXT=""
  fi

  if [[ -n "$PARSED_TEXT" ]]; then
    if command -v tput >/dev/null 2>&1; then
      tput setaf 6
    fi
    printf '\n--- Response ---\n\n'
    if command -v tput >/dev/null 2>&1; then
      tput sgr0
    fi

    if [[ "$USE_BAT" == true ]] && command -v bat >/dev/null 2>&1; then
      # Only nag the user with "Sent to bat..." if the response is tall enough
      # to actually summon bat's pager. tput lines reports the terminal height; default to 24.
      local TERM_LINES RESPONSE_LINES
      TERM_LINES="$(tput lines 2>/dev/null || printf '24')"
      RESPONSE_LINES="$(printf '%s\n' "$PARSED_TEXT" | wc -l)"
      if ((RESPONSE_LINES >= TERM_LINES)); then
        if command -v tput >/dev/null 2>&1; then
          tput setaf 11
        fi
        printf '%s\n' "Sent to bat..."
        if command -v tput >/dev/null 2>&1; then
          tput sgr0
        fi
      fi
      printf '%s\n' "$PARSED_TEXT" | bat --language=markdown --style=plain
    else
      if command -v tput >/dev/null 2>&1; then
        tput setaf 14
      fi
      printf '%s\n' "$PARSED_TEXT"
      if command -v tput >/dev/null 2>&1; then
        tput sgr0
      fi
    fi
    if command -v tput >/dev/null 2>&1; then
      tput setaf 6
    fi
    printf '\n----------------\n\n'
    if command -v tput >/dev/null 2>&1; then
      tput sgr0
    fi
  else
    # No content was parsed. Distinguish provider errors from other failures.
    if command -v tput >/dev/null 2>&1; then
      tput setaf 1
    fi
    local ERR_MSG ERR_CODE ERR_TYPE
    ERR_MSG="$(printf '%s' "$RESPONSE" | jq -r '.error.message // empty')" || ERR_MSG=""
    ERR_CODE="$(printf '%s' "$RESPONSE" | jq -r '.error.code // empty')" || ERR_CODE=""
    ERR_TYPE="$(printf '%s' "$RESPONSE" | jq -r '.error.type // empty')" || ERR_TYPE=""
    if [[ -n "$ERR_MSG" ]]; then
      printf 'API Error: %s\n' "$ERR_MSG"
      if [[ -n "$ERR_CODE" ]]; then
        printf 'Code: %s\n' "$ERR_CODE"
      fi
      if [[ -n "$ERR_TYPE" ]]; then
        printf 'Type: %s\n' "$ERR_TYPE"
      fi
    else
      printf '%s\n' "Processing Error: Could not extract text from the response payload."
      printf '%s\n' "Raw diagnostic response:"
      printf '%.240s\n' "$RESPONSE"
    fi
    if command -v tput >/dev/null 2>&1; then
      tput sgr0
    fi
  fi

  # Wipe the API key from memory before we go. Loose keys sink scripts.
  API_KEY=""
}

# Pass the API key extracted at the top level into main, then the rest of the
# script's arguments. The global API_KEY is cleared after main returns.
main "$API_KEY" "$@"
API_KEY=""
